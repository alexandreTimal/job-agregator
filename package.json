{
  "name": "job-agregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agrégateur de jobboards maison : fetch par termes choisis, filtrage déterministe, export Notion.",
  "scripts": {
    "fetch": "tsx src/index.ts",
    "fetch:dry": "tsx src/index.ts --dry-run",
    "typecheck": "tsc --noEmit",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "playwright": "^1.51.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
