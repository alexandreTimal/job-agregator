{
  "name": "job-agregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agrégateur de jobboards maison : fetch par termes choisis, filtrage déterministe, UI web locale.",
  "scripts": {
    "fetch": "tsx src/index.ts",
    "fetch:dry": "tsx src/index.ts --dry-run",
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "playwright": "^1.51.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
