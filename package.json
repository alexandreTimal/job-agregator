{
  "name": "job-agregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agrégateur de jobboards maison : fetch par termes choisis, filtrage déterministe, UI web locale.",
  "scripts": {
    "fetch": "tsx src/index.ts",
    "fetch:dry": "tsx src/index.ts --dry-run",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "wttj:login": "tsx src/tools/wttj-login.ts",
    "build": "vite build",
    "start": "vite build && tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.2.1",
    "lucide-react": "^1.17.0",
    "playwright": "^1.51.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
