# job-agregator — variables d'environnement (toutes OPTIONNELLES).
# Copier en `.env` (gitignored). Aucun secret en clair dans le repo.

# Niveau de log (DEBUG < INFO < WARN < ERROR). Défaut : INFO.
# LOG_LEVEL=DEBUG

# Chemin custom de la base sqlite. Défaut : ./data/job-agregator.db
# JOB_AGREGATOR_DB=./data/job-agregator.db

# WTTJ — chemin du storageState Playwright (session authentifiée).
# Défaut : ./data/wttj-session.json (gitignored). Généré par `npm run wttj:login`.
# WTTJ_STORAGE_STATE=./data/wttj-session.json
